<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0" ExtensionBundleId="com.recorteap.panel" ExtensionBundleVersion="1.0.0"
    ExtensionBundleName="RecorteAP" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <ExtensionList>
        <Extension Id="com.recorteap.panel" Version="1.0.0" />
    </ExtensionList>
    <ExecutionEnvironment>
        <HostList>
            <Host Name="PHXS" Version="[15.0,99.9]" />
            <Host Name="PHSP" Version="[15.0,99.9]" />
        </HostList>
        <LocaleList>
            <Locale Code="All" />
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="7.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>
    <DispatchInfoList>
        <Extension Id="com.recorteap.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./index.html</MainPath>
                    <ScriptPath>./host/index.jsx</ScriptPath>
                    <CEFCommandLine>
                        <Parameter>--enable-nodejs</Parameter>
                        <Parameter>--mixed-context</Parameter>
                    </CEFCommandLine>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>RecorteAP</Menu>
                    <Geometry>
                        <Size>
                            <Height>600</Height>
                            <Width>300</Width>
                        </Size>
                        <MinSize>
                            <Height>400</Height>
                            <Width>250</Width>
                        </MinSize>
                        <MaxSize>
                            <Height>2000</Height>
                            <Width>2000</Width>
                        </MaxSize>
                    </Geometry>
                    <Icons>
                        <Icon Type="Normal" Path="./icons/icon16.png"/>
                        <Icon Type="RollOver" Path="./icons/icon16.png"/>
                        <Icon Type="Disabled" Path="./icons/icon16.png"/>
                        <Icon Type="DarkNormal" Path="./icons/icon16.png"/>
                        <Icon Type="DarkRollOver" Path="./icons/icon16.png"/>
                        <Icon Type="Normal" Path="./icons/icon24.png"/>
                        <Icon Type="Normal" Path="./icons/icon32.png"/>
                        <Icon Type="Normal" Path="./icons/icon48.png"/>
                        <Icon Type="Normal" Path="./icons/icon64.png"/>
                        <Icon Type="Normal" Path="./icons/icon128.png"/>
                    </Icons>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>